# Copy this to .env and fill in real values for local dev
# Railway sets these automatically in the dashboard — never commit .env

# ── Flask ─────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────
# Railway Postgres: set automatically when you add a Postgres plugin
# Locally: leave blank to use SQLite (players.db)
DATABASE_URL=

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Leave as * for development; set to your real domain in production
FRONTEND_ORIGIN=*

# ── Domain / URL normalization ────────────────────────────────────
# Optional: redirect all traffic to one canonical host and enforce HTTPS
# Example for production:
# CANONICAL_HOST=jkrek.com
# FORCE_HTTPS=true
CANONICAL_HOST=
FORCE_HTTPS=false

# ── Auth0 (optional) ─────────────────────────────────────────────
REACT_APP_AUTH0_DOMAIN=
REACT_APP_AUTH0_CLIENT_ID=

# ── Feature flags ─────────────────────────────────────────────────
# Set to false to skip auto-sync on first boot (saves time on cold start)
AUTO_SYNC_COLLEGE_PROSPECTS=false
